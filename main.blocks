<xml xmlns="https://developers.google.com/blockly/xml"><variables></variables><block type="pxt-on-start" id="WY]XKW-9K7YS8Hc$teKG" x="20" y="20"><statement name="HANDLER"><block type="typescript_statement" id="zg3P!rM7t|itIR=Bl#WS"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="namespace bqd357 {" line1="" line2="    let isGnssSerial = false;" line3="    let lastGGA: string = &quot;&quot;;" line4="    let lastRMC: string = &quot;&quot;;" line5="    let lastVTG: string = &quot;&quot;;" line6="    let lastGSA: string = &quot;&quot;;" line7="    let lastGSV: string = &quot;&quot;;" line8="    let gpsSatellites: Satellite[] = [];" line9="    let bdsSatellites: Satellite[] = [];" line10="" line11="    interface Satellite {" line12="        id: number;" line13="        elevation: number;" line14="        azimuth: number;" line15="        snr: number;" line16="    }" line17="" line18="    let lastValidFixMs = 0;" line19="" line20="    // -------------------------------------------------------------------------" line21="    // Serial port switching" line22="    // -------------------------------------------------------------------------" line23="" line24="    /**" line25="     * Switch serial to GNSS module pins (P1 = RX ← module TX, P2 = TX → module RX)" line26="     */" line27="    //% block=&quot;use GNSS serial P1 as RX &amp; P2 as TX baud $baud&quot;" line28="    //% group=&quot;GNSS&quot; weight=100" line29="    export function useGnssSerial(baud: number = 115200): void {" line30="        serial.redirect(SerialPin.P1, SerialPin.P2, baud);" line31="        isGnssSerial = true;" line32="        basic.pause(50);" line33="    }" line34="" line35="    /**" line36="     * Switch serial back to USB console" line37="     */" line38="    //% block=&quot;use USB serial console&quot;" line39="    //% group=&quot;Output&quot; weight=90" line40="    export function useUsbSerial(): void {" line41="        serial.redirectToUSB();" line42="        isGnssSerial = false;" line43="        basic.pause(50);" line44="    }" line45="" line46="    /**" line47="     * Read and parse one line from GNSS module" line48="     */" line49="    //% block=&quot;read &amp; parse one NMEA line&quot;" line50="    //% group=&quot;GNSS&quot; weight=80" line51="    export function readAndParseLine(): void {" line52="        if (!isGnssSerial) return;" line53="" line54="        let line = serial.readLine();" line55="" line56="        if (!line || line.length &lt; 8 || line.charAt(0) !== &quot;$&quot;) return;" line57="" line58="        let parts = line.split(&quot;,&quot;);" line59="        if (parts.length &lt; 3) return;" line60="" line61="        let talker = parts[0].substr(1, 2);" line62="        let sentence = parts[0].substr(3, 3);" line63="" line64="        // Store last sentences" line65="        if (sentence === &quot;GGA&quot;) lastGGA = line;" line66="        else if (sentence === &quot;RMC&quot;) lastRMC = line;" line67="        else if (sentence === &quot;VTG&quot;) lastVTG = line;" line68="        else if (sentence === &quot;GSA&quot;) lastGSA = line;" line69="        else if (sentence === &quot;GSV&quot;) {" line70="            lastGSV = line;" line71="            parseGSV(line);" line72="        }" line73="" line74="        // Update fix status timestamp" line75="        if (sentence === &quot;GGA&quot; || sentence === &quot;RMC&quot;) {" line76="            if ((parts.length &gt; 6 &amp;&amp; (parts[6] === &quot;1&quot; || parts[6] === &quot;2&quot;)) ||" line77="                (parts.length &gt; 2 &amp;&amp; parts[2] === &quot;A&quot;)) {" line78="                lastValidFixMs = control.millis();" line79="            }" line80="        }" line81="    }" line82="" line83="    function parseGSV(line: string): void {" line84="        let parts2 = line.split(&quot;,&quot;);" line85="        if (parts2.length &lt; 8) return;" line86="" line87="        let talker2 = parts2[0].substr(1, 2);" line88="        let isBDS = (talker2 === &quot;BD&quot; || talker2 === &quot;GB&quot;);" line89="" line90="        let idx = 4;" line91="        let satellites = isBDS ? bdsSatellites : gpsSatellites;" line92="" line93="        while (idx + 3 &lt; parts2.length) {" line94="            let idRaw = parts2[idx++];" line95="            let elvRaw = parts2[idx++];" line96="            let azRaw = parts2[idx++];" line97="            let snrRaw = parts2[idx++];" line98="" line99="            if (!idRaw) continue;  // Changed: Only skip if no ID; allow empty SNR" line100="" line101="            let id = parseInt(idRaw);" line102="            let elv = parseInt(elvRaw) || 0;" line103="            let az = parseInt(azRaw) || 0;" line104="            let snr = parseInt(snrRaw) || 0;  // Changed: Default to 0 if empty or invalid" line105="" line106="            if (id &gt; 0) {  // Changed: Remove '&amp;&amp; snr &gt; 0' to include low/zero SNR satellites" line107="                let sat: Satellite = { id: id, elevation: elv, azimuth: az, snr: snr };" line108="" line109="                let pos = -1;" line110="                for (let i = 0; i &lt; satellites.length; i++) {" line111="                    if (satellites[i].id === id) {" line112="                        pos = i;" line113="                        break;" line114="                    }" line115="                }" line116="" line117="                if (pos &gt;= 0) {" line118="                    satellites[pos] = sat;" line119="                } else {" line120="                    satellites.push(sat);" line121="                }" line122="            }" line123="        }" line124="" line125="        // Limit list size (memory safety on micro:bit)" line126="        if (satellites.length &gt; 32) {" line127="            satellites = satellites.slice(-28);" line128="        }" line129="    }" line130="" line131="    // -------------------------------------------------------------------------" line132="    // Status &amp; position getters (return formatted strings)" line133="    // -------------------------------------------------------------------------" line134="" line135="    /**" line136="     * GNSS working status: &quot;outdoor&quot; or &quot;indoor&quot;" line137="     */" line138="    //% block=&quot;GNSS status&quot;" line139="    //% group=&quot;GNSS&quot; weight=70" line140="    export function status(): string {" line141="        // Prefer direct sentence evidence first" line142="        let fixGGA = extractField(lastGGA, 6);" line143="        if (fixGGA === &quot;1&quot; || fixGGA === &quot;2&quot; || fixGGA === &quot;4&quot;) {" line144="            lastValidFixMs = control.millis();  // update timestamp here too" line145="            return &quot;outdoor&quot;;" line146="        }" line147="" line148="        let fixRMC = extractField(lastRMC, 2);" line149="        if (fixRMC === &quot;A&quot;) {" line150="            lastValidFixMs = control.millis();" line151="            return &quot;outdoor&quot;;" line152="        }" line153="" line154="        // Age-based fallback only if no recent sentence evidence" line155="        let age = control.millis() - lastValidFixMs;" line156="        if (age &gt; 12000) return &quot;indoor&quot;;  // more lenient than 8s" line157="" line158="        // Satellite fallback (only used if sentences are old)" line159="        let total = gpsSatellites.length + bdsSatellites.length;" line160="        let good = 0;" line161="        for (let s of gpsSatellites) if (s.snr &gt;= 28) good++;  // slightly lower threshold" line162="        for (let t of bdsSatellites) if (t.snr &gt;= 28) good++;" line163="" line164="        return (total &gt;= 5 &amp;&amp; good &gt;= 3) ? &quot;outdoor&quot; : &quot;indoor&quot;;" line165="    }" line166="" line167="    /**" line168="     * UTC time HH:MM:SS or empty string" line169="     */" line170="    //% block=&quot;UTC time&quot;" line171="    //% group=&quot;GNSS&quot;" line172="    export function utcTime(): string {" line173="        let u = extractField(lastGGA, 1) || extractField(lastRMC, 1);" line174="        if (!u || u.length &lt; 6) return &quot;&quot;;" line175="        let hh = u.substr(0, 2);" line176="        let mm = u.substr(2, 2);" line177="        let ss = u.substr(4, 2);" line178="        return hh + &quot;:&quot; + mm + &quot;:&quot; + ss;" line179="    }" line180="" line181="    /**" line182="     * Latitude with 6 decimal places or &quot;(no fix)&quot;" line183="     */" line184="    //% block=&quot;latitude&quot;" line185="    //% group=&quot;GNSS&quot;" line186="    export function latitude(): string {" line187="        if (status() !== &quot;outdoor&quot;) return &quot;(no fix)&quot;;" line188="" line189="        let raw = extractField(lastGGA, 2) || extractField(lastRMC, 3);" line190="        if (!raw || raw.length &lt; 4) return &quot;(no fix)&quot;;" line191="" line192="        let deg = parseInt(raw.substr(0, 2));" line193="        let min = parseFloat(raw.substr(2));" line194="        let dec = deg + min / 60;" line195="" line196="        let ns = extractField(lastGGA, 3) || extractField(lastRMC, 4);" line197="        if (ns === &quot;S&quot;) dec = -dec;" line198="" line199="        return &quot;&quot; + (Math.round(dec * 1000000) / 1000000);" line200="    }" line201="" line202="    /**" line203="     * Longitude with 6 decimal places or &quot;(no fix)&quot;" line204="     */" line205="    //% block=&quot;longitude&quot;" line206="    //% group=&quot;GNSS&quot;" line207="    export function longitude(): string {" line208="        if (status() !== &quot;outdoor&quot;) return &quot;(no fix)&quot;;" line209="" line210="        let raw2 = extractField(lastGGA, 4) || extractField(lastRMC, 5);" line211="        if (!raw2 || raw2.length &lt; 5) return &quot;(no fix)&quot;;" line212="" line213="        let deg2 = parseInt(raw2.substr(0, 3));" line214="        let min2 = parseFloat(raw2.substr(3));" line215="        let dec2 = deg2 + min2 / 60;" line216="" line217="        let ew = extractField(lastGGA, 5) || extractField(lastRMC, 6);" line218="        if (ew === &quot;W&quot;) dec2 = -dec2;" line219="" line220="        return &quot;&quot; + (Math.round(dec2 * 1000000) / 1000000);" line221="    }" line222="" line223="    /**" line224="     * Speed in km/h with 1 decimal place or &quot;(no fix)&quot;" line225="     */" line226="    //% block=&quot;speed (km/h)&quot;" line227="    //% group=&quot;GNSS&quot;" line228="    export function speedKmh(): string {" line229="        if (status() !== &quot;outdoor&quot;) return &quot;(no fix)&quot;;" line230="" line231="        let vtg = extractField(lastVTG, 7);" line232="        if (vtg &amp;&amp; vtg !== &quot;&quot;) {" line233="            let v = parseFloat(vtg);" line234="            return &quot;&quot; + (Math.round(v * 10) / 10);" line235="        }" line236="" line237="        let rmc = extractField(lastRMC, 7);" line238="        if (rmc &amp;&amp; rmc !== &quot;&quot;) {" line239="            let w = parseFloat(rmc) * 1.852;" line240="            return &quot;&quot; + (Math.round(w * 10) / 10);" line241="        }" line242="" line243="        return &quot;(no fix)&quot;;" line244="    }" line245="" line246="    // -------------------------------------------------------------------------" line247="    // Satellite information" line248="    // -------------------------------------------------------------------------" line249="    //% block=&quot;debugDumpSatellites $isBeiDou&quot;" line250="    //% group=&quot;Satellites&quot;" line251="    //% advanced=true" line252="    export function debugDumpSatellites(isBeiDou: boolean = true): string {" line253="        const sats = isBeiDou ? bdsSatellites : gpsSatellites;" line254="        let dump = &quot;&quot;;" line255="        for (let j = 0; j &lt; sats.length; j++) {" line256="            const a = sats[j];" line257="            dump += &quot;Index &quot; + j + &quot;: ID=&quot; + a.id + &quot;, el=&quot; + a.elevation + &quot;, az=&quot; + a.azimuth + &quot;, snr=&quot; + a.snr + &quot;\n&quot;;" line258="        }" line259="        return dump || &quot;Empty array&quot;;" line260="    }" line261="" line262="    //% block=&quot;number of Beidou Satellites $isBeiDou&quot;&quot;" line263="    //% group=&quot;Satellites&quot;" line264="    export function satelliteCount(isBeiDou: boolean = true): number {" line265="        const len = isBeiDou ? bdsSatellites.length : bdsSatellites.length;" line266="        return len;" line267="    }" line268="" line269="    //% block=&quot;Beidou Satellite info $index $isBeiDou&quot;&quot;" line270="    //% group=&quot;Satellites&quot;" line271="    export function satelliteInfo(index: number, isBeiDou: boolean = true): string {" line272="        const sats2 = isBeiDou ? bdsSatellites : gpsSatellites;" line273="" line274="        if (index &lt; 0 || index &gt;= sats2.length) {" line275="            return &quot;—&quot;;" line276="        }" line277="" line278="        let b = sats2[index];" line279="" line280="        return &quot;ID: &quot; + b.id.toString() + &quot; El: &quot; + b.elevation.toString() + &quot;deg Az: &quot; + b.azimuth.toString() + &quot;deg SNR: &quot; + b.snr.toString() + &quot;dB&quot;;" line281="    }" line282="" line283="    /**" line284="     * Returns the formatted satellite PRN string." line285="     * @param index The index in the satellites array" line286="     * @param isBeiDou Whether to use BeiDou (bdsSatellites) instead of GPS" line287="     * @returns Formatted PRN (e.g., &quot;ID 12&quot;) or &quot;—&quot; if invalid" line288="     */" line289="    //% block=&quot;Beidou satellitePRN $index $isBeiDou&quot;&quot;" line290="    //% group=&quot;Satellites&quot;" line291="    export function satelliteId(index: number, isBeiDou: boolean = true): string {" line292="        const sats3 = isBeiDou ? bdsSatellites : gpsSatellites;" line293="        if (index &lt; 0 || index &gt;= sats3.length) return &quot;—&quot;;" line294="        const id2 = sats3[index].id;" line295="        return id2.toString();" line296="    }" line297="" line298="    /**" line299="     * Returns the formatted altitude string." line300="     * @param index The index in the satellites array" line301="     * @param isBeiDou Whether to use BeiDou array" line302="     * @returns Formatted altitude (e.g., &quot;el:65°&quot;) or &quot;—&quot; if invalid" line303="     */" line304="    //% block=&quot;Beidou satellite Altitude $index $isBeiDou&quot;&quot;" line305="    //% group=&quot;Satellites&quot;" line306="    export function satelliteElevation(index: number, isBeiDou: boolean = true): string {" line307="        const sats4 = isBeiDou ? bdsSatellites : gpsSatellites;" line308="        if (index &lt; 0 || index &gt;= sats4.length) return &quot;—&quot;;" line309="        const el = sats4[index].elevation;" line310="        return el.toString();" line311="    }" line312="" line313="    /**" line314="     * Returns the formatted azimuth string." line315="     * @param index The index in the satellites array" line316="     * @param isBeiDou Whether to use BeiDou array" line317="     * @returns Formatted azimuth (e.g., &quot;az:220°&quot;) or &quot;—&quot; if invalid" line318="     */" line319="    //% block=&quot;Beidou satellite Azimuth $index $isBeiDou&quot;&quot;" line320="    //% group=&quot;Satellites&quot;" line321="    export function satelliteAzimuth(index: number, isBeiDou: boolean = true): string {" line322="        const sats5 = isBeiDou ? bdsSatellites : gpsSatellites;" line323="        if (index &lt; 0 || index &gt;= sats5.length) return &quot;—&quot;;" line324="        const az2 = sats5[index].azimuth;" line325="        return az2.toString();" line326="    }" line327="" line328="    /**" line329="     * Returns the formatted SNR string." line330="     * @param index The index in the satellites array" line331="     * @param isBeiDou Whether to use BeiDou array" line332="     * @returns Formatted SNR (e.g., &quot;38dB&quot;) or &quot;—&quot; if invalid" line333="     */" line334="    //% block=&quot;Beidou satellite SNR $index $isBeiDou&quot;&quot;" line335="    //% group=&quot;Satellites&quot;" line336="    export function satelliteSnr(index: number, isBeiDou: boolean = true): string {" line337="        const sats6 = isBeiDou ? bdsSatellites : gpsSatellites;" line338="        if (index &lt; 0 || index &gt;= sats6.length) return &quot;—&quot;;" line339="        const snr2 = sats6[index].snr;" line340="        return snr2.toString();" line341="    }" line342="    // -------------------------------------------------------------------------" line343="    // Raw NMEA sentences (last received)" line344="    // -------------------------------------------------------------------------" line345="" line346="    //% block=&quot;raw GGA&quot;" line347="    //% group=&quot;Raw NMEA&quot; weight=60" line348="    //% advanced=true" line349="    export function rawGGA(): string {" line350="        return lastGGA || &quot;&quot;;" line351="    }" line352="" line353="    //% block=&quot;raw RMC&quot;" line354="    //% group=&quot;Raw NMEA&quot; weight=59" line355="    //% advanced=true" line356="    export function rawRMC(): string {" line357="        return lastRMC || &quot;&quot;;" line358="    }" line359="" line360="    //% block=&quot;raw VTG&quot;" line361="    //% group=&quot;Raw NMEA&quot; weight=58" line362="    //% advanced=true" line363="    export function rawVTG(): string {" line364="        return lastVTG || &quot;&quot;;" line365="    }" line366="" line367="    //% block=&quot;raw GSA (last)&quot;" line368="    //% group=&quot;Raw NMEA&quot; weight=57" line369="    //% advanced=true" line370="    export function rawGSA(): string {" line371="        return lastGSA || &quot;&quot;;" line372="    }" line373="" line374="    //% block=&quot;raw GSV (last received)&quot;" line375="    //% group=&quot;Raw NMEA&quot; weight=56" line376="    //% advanced=true" line377="    export function rawGSV(): string {" line378="        return lastGSV || &quot;&quot;;" line379="    }" line380="" line381="    // -------------------------------------------------------------------------" line382="    // Utility" line383="    // -------------------------------------------------------------------------" line384="" line385="    function extractField(sentence: string, idx: number): string {" line386="        if (!sentence) return &quot;&quot;;" line387="        let p = sentence.split(&quot;,&quot;);" line388="        return idx &lt; p.length ? p[idx] : &quot;&quot;;" line389="    }" line390="" line391="    //% block=&quot;clear satellite lists&quot;" line392="    //% group=&quot;GNSS&quot; advanced=true" line393="    export function clearSatellites(): void {" line394="        gpsSatellites = [];" line395="        bdsSatellites = [];" line396="    }" line397="    // ────────────────────────────────────────────────" line398="    // Robust padStart polyfill for MakeCode runtime" line399="    // ────────────────────────────────────────────────" line400="    function padStart(str: string, targetLength: number, padChar: string = &quot; &quot;): string {" line401="        // Handle null/undefined input" line402="        if (str === undefined || str === null) {" line403="            str = &quot;0&quot;;" line404="        }" line405="" line406="        // Convert to string if not already" line407="        //str = String(str);" line408="" line409="        // Handle invalid arguments" line410="        if (targetLength &lt;= 0) {" line411="            return str;" line412="        }" line413="" line414="        if (padChar === undefined || padChar === null) {" line415="            padChar = &quot; &quot;;" line416="        }" line417="        //padChar = String(padChar);" line418="" line419="        if (str.length &gt;= targetLength) {" line420="            return str;" line421="        }" line422="" line423="        const paddingNeeded = targetLength - str.length;" line424="        let padding = &quot;&quot;;" line425="" line426="        // Build padding efficiently" line427="        while (padding.length &lt; paddingNeeded) {" line428="            if (padding.length + padChar.length &lt;= paddingNeeded) {" line429="                padding += padChar;" line430="            } else {" line431="                padding += padChar.slice(0, paddingNeeded - padding.length);" line432="            }" line433="        }" line434="" line435="        return padding + str;" line436="    }" line437="}" numlines="438"></mutation></block></statement></block></xml>